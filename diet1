import { useState } from "react";

const DIAS = ["Segunda", "Terça", "Quarta", "Quinta", "Sexta"];

function calcIMC(peso, altura) {
  const h = altura / 100;
  return (peso / (h * h)).toFixed(1);
}

function calcTMB(peso, altura, idade, sexo) {
  if (sexo === "masculino") return Math.round(88.36 + 13.4 * peso + 4.8 * altura - 5.7 * idade);
  return Math.round(447.6 + 9.2 * peso + 3.1 * altura - 4.3 * idade);
}

function imcInfo(v) {
  const n = Number(v);
  if (n < 18.5) return { label: "Abaixo do peso", cor: "#64b5f6" };
  if (n < 25)   return { label: "Peso normal",    cor: "#4ade80" };
  if (n < 30)   return { label: "Sobrepeso",      cor: "#fbbf24" };
  return             { label: "Obesidade",         cor: "#f87171" };
}

async function chamarClaude(prompt) {
  const res = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      system: "Responde APENAS com JSON válido. Sem texto extra. Sem markdown. Sem explicações.",
      messages: [{ role: "user", content: prompt }]
    })
  });
  if (!res.ok) throw new Error(`Erro ${res.status}`);
  const data = await res.json();
  const texto = data.content?.find(b => b.type === "text")?.text || "";
  const match = texto.match(/\{[\s\S]*\}/);
  if (!match) throw new Error("JSON inválido");
  return JSON.parse(match[0]);
}

export default function App() {
  const [etapa, setEtapa]     = useState("form");
  const [form, setForm]       = useState({ nome: "", idade: "", peso: "", altura: "", sexo: "masculino" });
  const [erro, setErro]       = useState("");
  const [loading, setLoading] = useState(false);
  const [progresso, setProgresso] = useState({ atual: 0, total: 0, msg: "" });

  // plano[modo][diaIndex] = { refeicoes: [...] }
  const [plano, setPlano]     = useState({ perda: [], muscular: [] });
  const [resumo, setResumo]   = useState(null);

  const [modo, setModo]       = useState("perda");
  const [diaAtivo, setDiaAtivo] = useState(0);

  const handleChange = e => setForm({ ...form, [e.target.name]: e.target.value });

  async function gerar() {
    const { nome, idade, peso, altura, sexo } = form;
    if (!idade || !peso || !altura) { setErro("Preenche todos os campos."); return; }
    if (Number(idade) < 10 || Number(idade) > 100) { setErro("Idade inválida (10–100)."); return; }
    if (Number(peso)  < 30 || Number(peso)  > 300) { setErro("Peso inválido (30–300 kg)."); return; }
    if (Number(altura)< 100|| Number(altura)> 250) { setErro("Altura inválida (100–250 cm)."); return; }

    setErro("");
    setLoading(true);

    const imc      = calcIMC(Number(peso), Number(altura));
    const tmb      = calcTMB(Number(peso), Number(altura), Number(idade), sexo);
    const calPerda = tmb - 400;
    const calMus   = tmb + 300;

    const perfil = `Pessoa: ${nome || "utilizador"}, ${idade} anos, ${peso}kg, ${altura}cm, ${sexo}. IMC ${imc}. Ingredientes de Maputo, Moçambique: frango, peixe (carapau/tilápia/atum), camarão, ovos, carne de vaca, feijão, feijão-nhemba, mandioca, batata-doce, xima, arroz, pão integral, couve, espinafre, tomate, cebola, alho, cenoura, pepino, abacate, papaia, manga, banana, laranja, amendoim, castanha de caju, leite, iogurte natural, azeite, limão.`;

    try {
      // 1. Resumo
      setProgresso({ atual: 1, total: 11, msg: "A calcular perfil..." });
      const res = await chamarClaude(`${perfil}
Devolve JSON: {"imc":"${imc}","classificacao":"string","calPerda":${calPerda},"calMus":${calMus},"dica":"uma dica curta personalizada"}`);
      setResumo(res);

      const novoPlano = { perda: [], muscular: [] };

      // 2–6: dias perda
      for (let i = 0; i < 5; i++) {
        setProgresso({ atual: 2 + i, total: 11, msg: `Perda de gordura – ${DIAS[i]}...` });
        const dia = await chamarClaude(`${perfil} Objetivo: perda de gordura, ~${calPerda} kcal/dia.
Cria o plano alimentar para ${DIAS[i]}-feira com 5 refeições.
JSON: {"refeicoes":[{"nome":"emoji Nome","hora":"HH:MM","itens":["item com quantidade","..."]},...]}`);
        novoPlano.perda.push(dia);
      }

      // 7–11: dias muscular
      for (let i = 0; i < 5; i++) {
        setProgresso({ atual: 7 + i, total: 11, msg: `Ganho muscular – ${DIAS[i]}...` });
        const dia = await chamarClaude(`${perfil} Objetivo: ganho muscular, ~${calMus} kcal/dia.
Cria o plano alimentar para ${DIAS[i]}-feira com 6 refeições (inclui pré e pós-treino).
JSON: {"refeicoes":[{"nome":"emoji Nome","hora":"HH:MM","itens":["item com quantidade","..."]},...]}`);
        novoPlano.muscular.push(dia);
      }

      setPlano(novoPlano);
      setEtapa("plano");
    } catch (e) {
      setErro("Algo correu mal: " + e.message + ". Tenta novamente.");
      console.error(e);
    } finally {
      setLoading(false);
    }
  }

  // ── CORES ──
  const ac = modo === "perda" ? "#00e5c3" : "#f59e0b";
  const acDim = modo === "perda" ? "#00e5c318" : "#f59e0b18";

  // ── FORMULÁRIO ──
  if (etapa === "form") return (
    <div style={{ minHeight:"100vh", background:"#080c14", display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", padding:"1.5rem", fontFamily:"'Segoe UI',sans-serif" }}>
      <style>{`
        *{box-sizing:border-box}
        .inp{width:100%;background:#131d2e;border:1.5px solid #1e2d42;border-radius:10px;padding:.75rem 1rem;color:#e8edf5;font-size:.95rem;outline:none;transition:.2s}
        .inp:focus{border-color:#00e5c3;box-shadow:0 0 0 3px #00e5c322}
        .lbl{display:block;font-size:.68rem;letter-spacing:1.5px;text-transform:uppercase;color:#6b7fa3;margin-bottom:.35rem}
        .sbtn{flex:1;padding:.65rem;border-radius:8px;border:1.5px solid #1e2d42;background:#131d2e;color:#6b7fa3;cursor:pointer;font-size:.82rem;transition:.2s}
        .sbtn.on{border-color:#00e5c3;background:#00e5c318;color:#00e5c3}
        .gbtn{width:100%;padding:1rem;border-radius:12px;border:none;cursor:pointer;font-size:1rem;font-weight:700;background:linear-gradient(135deg,#00b894,#00e5c3);color:#080c14;margin-top:1.4rem;transition:.15s}
        .gbtn:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 24px #00e5c344}
        .gbtn:disabled{opacity:.45;cursor:not-allowed}
      `}</style>

      <div style={{ width:"100%", maxWidth:"400px" }}>
        <div style={{ textAlign:"center", marginBottom:"2rem" }}>
          <div style={{ fontSize:"2.8rem" }}>🌿</div>
          <h1 style={{ margin:".4rem 0 0", color:"#e8edf5", fontSize:"1.7rem", fontWeight:700 }}>Dieta Personalizada</h1>
          <p style={{ margin:".4rem 0 0", color:"#6b7fa3", fontSize:".82rem" }}>Maputo · Ingredientes locais · Plano à tua medida</p>
        </div>

        <div style={{ background:"#0e1520", borderRadius:"18px", padding:"1.6rem", border:"1px solid #1e2d42" }}>
          <div style={{ display:"flex", flexDirection:"column", gap:"1rem" }}>
            <div>
              <label className="lbl">Nome (opcional)</label>
              <input className="inp" name="nome" value={form.nome} onChange={handleChange} placeholder="Ex: Carlos" />
            </div>
            <div style={{ display:"flex", gap:".8rem" }}>
              <div style={{ flex:1 }}>
                <label className="lbl">Idade</label>
                <input className="inp" name="idade" type="number" value={form.idade} onChange={handleChange} placeholder="25" />
              </div>
              <div style={{ flex:1 }}>
                <label className="lbl">Peso (kg)</label>
                <input className="inp" name="peso" type="number" value={form.peso} onChange={handleChange} placeholder="70" />
              </div>
            </div>
            <div>
              <label className="lbl">Altura (cm)</label>
              <input className="inp" name="altura" type="number" value={form.altura} onChange={handleChange} placeholder="170" />
            </div>
            <div>
              <label className="lbl">Sexo</label>
              <div style={{ display:"flex", gap:".5rem" }}>
                {["masculino","feminino"].map(s => (
                  <button key={s} className={`sbtn${form.sexo===s?" on":""}`} onClick={() => setForm({...form, sexo:s})}>
                    {s==="masculino" ? "♂ Masculino" : "♀ Feminino"}
                  </button>
                ))}
              </div>
            </div>
          </div>

          {erro && <p style={{ color:"#f87171", fontSize:".78rem", marginTop:".9rem", textAlign:"center" }}>{erro}</p>}

          {loading ? (
            <div style={{ marginTop:"1.4rem" }}>
              <div style={{ background:"#1e2d42", borderRadius:"8px", height:"6px", overflow:"hidden" }}>
                <div style={{ background:"linear-gradient(90deg,#00b894,#00e5c3)", height:"100%", width:`${(progresso.atual/progresso.total)*100}%`, transition:"width .4s ease", borderRadius:"8px" }} />
              </div>
              <p style={{ color:"#6b7fa3", fontSize:".75rem", textAlign:"center", margin:".6rem 0 0" }}>
                {progresso.msg} ({progresso.atual}/{progresso.total})
              </p>
            </div>
          ) : (
            <button className="gbtn" onClick={gerar}>✨ Gerar Plano Personalizado</button>
          )}
        </div>
        <p style={{ textAlign:"center", fontSize:".62rem", color:"#2a3a53", marginTop:"1rem" }}>
          Gerado por IA · Consulta um nutricionista para acompanhamento clínico
        </p>
      </div>
    </div>
  );

  // ── PLANO ──
  const diaData = plano[modo]?.[diaAtivo];
  const inf = resumo ? imcInfo(resumo.imc) : { label:"", cor:"#fff" };

  return (
    <div style={{ minHeight:"100vh", background:"#080c14", fontFamily:"'Segoe UI',sans-serif", color:"#e8edf5" }}>
      <style>{`
        *{box-sizing:border-box}
        ::-webkit-scrollbar{display:none}
        .dbtn{flex-shrink:0;padding:.4rem .9rem;border-radius:20px;cursor:pointer;font-size:.75rem;transition:.2s;white-space:nowrap}
        .mbtn{flex:1;padding:.7rem;border:none;cursor:pointer;font-weight:700;font-size:.8rem;transition:.3s}
        .rcard{border-radius:13px;padding:.9rem;margin-bottom:.65rem;border:1px solid #1e2d42;transition:.15s}
        .rcard:hover{transform:translateX(3px)}
        .vbtn{background:none;border:1px solid #1e2d42;color:#6b7fa3;border-radius:8px;padding:.35rem .8rem;cursor:pointer;font-size:.72rem;transition:.2s}
        .vbtn:hover{border-color:#6b7fa3;color:#e8edf5}
      `}</style>

      {/* Header */}
      <div style={{ background:"linear-gradient(160deg,#0e1520,#131d2e)", padding:"1.4rem 1.2rem 1.1rem", borderBottom:"1px solid #1e2d42" }}>
        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start", marginBottom:".9rem" }}>
          <div>
            <h1 style={{ margin:0, fontSize:"1.2rem", fontWeight:700 }}>Olá, {form.nome || "atleta"} 👋</h1>
            <p style={{ margin:".15rem 0 0", fontSize:".72rem", color:"#6b7fa3" }}>Plano personalizado · Maputo</p>
          </div>
          <button className="vbtn" onClick={() => { setEtapa("form"); setPlano({perda:[],muscular:[]}); setResumo(null); setDiaAtivo(0); }}>← Refazer</button>
        </div>

        {resumo && (
          <div style={{ display:"flex", gap:".6rem", marginBottom:".8rem" }}>
            {[
              { l:"IMC", v: resumo.imc, s: inf.label, c: inf.cor },
              { l:"Perda", v: resumo.calPerda, s:"kcal/dia", c:"#00e5c3" },
              { l:"Músculo", v: resumo.calMus, s:"kcal/dia", c:"#f59e0b" },
            ].map((x,i) => (
              <div key={i} style={{ flex:1, background:"#131d2e", borderRadius:"10px", padding:".65rem .4rem", textAlign:"center", border:"1px solid #1e2d42" }}>
                <div style={{ fontSize:".58rem", color:"#6b7fa3", textTransform:"uppercase", letterSpacing:"1px" }}>{x.l}</div>
                <div style={{ fontSize:".95rem", fontWeight:700, color:x.c, lineHeight:1.1 }}>{x.v}</div>
                <div style={{ fontSize:".58rem", color:"#6b7fa3" }}>{x.s}</div>
              </div>
            ))}
          </div>
        )}

        {resumo?.dica && (
          <div style={{ background: acDim, borderRadius:"8px", padding:".55rem .8rem", border:`1px solid ${ac}33` }}>
            <p style={{ margin:0, fontSize:".72rem", color:ac, lineHeight:1.5 }}>💡 {resumo.dica}</p>
          </div>
        )}
      </div>

      {/* Toggle modo */}
      <div style={{ display:"flex", margin:"1rem 1rem 0", borderRadius:"10px", overflow:"hidden", border:"1.5px solid #1e2d42" }}>
        {["perda","muscular"].map(m => (
          <button key={m} className="mbtn" onClick={() => { setModo(m); setDiaAtivo(0); }} style={{
            background: modo===m ? (m==="perda" ? "linear-gradient(135deg,#00b894,#00e5c3)" : "linear-gradient(135deg,#e65c00,#f9d423)") : "transparent",
            color: modo===m ? "#080c14" : "#6b7fa3",
          }}>
            {m==="perda" ? "⚖️ Perda de Gordura" : "💪 Ganho Muscular"}
          </button>
        ))}
      </div>

      {/* Dias */}
      <div style={{ display:"flex", gap:".5rem", padding:".9rem 1rem 0", overflowX:"auto" }}>
        {DIAS.map((d,i) => (
          <button key={i} className="dbtn" onClick={() => setDiaAtivo(i)} style={{
            border:`1.5px solid ${diaAtivo===i ? ac : "#1e2d42"}`,
            background: diaAtivo===i ? acDim : "transparent",
            color: diaAtivo===i ? ac : "#6b7fa3",
            fontWeight: diaAtivo===i ? 700 : 400,
          }}>{d}</button>
        ))}
      </div>

      {/* Refeições */}
      <div style={{ padding:"1rem" }}>
        {diaData?.refeicoes?.map((r,i) => (
          <div key={i} className="rcard" style={{ background:"#131d2e", borderLeft:`3px solid ${i===0 ? ac : "#1e2d42"}` }}>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:".5rem" }}>
              <span style={{ fontWeight:600, fontSize:".86rem" }}>{r.nome}</span>
              <span style={{ background:acDim, color:ac, borderRadius:"20px", padding:".08rem .5rem", fontSize:".68rem", fontFamily:"monospace" }}>{r.hora}</span>
            </div>
            <ul style={{ margin:0, paddingLeft:"1.1rem" }}>
              {r.itens?.map((item,j) => (
                <li key={j} style={{ fontSize:".78rem", marginBottom:".2rem", color:"#9aafc7", lineHeight:1.5 }}>{item}</li>
              ))}
            </ul>
          </div>
        ))}

        <p style={{ textAlign:"center", fontSize:".62rem", color:"#2a3a53", marginTop:"1.2rem" }}>
          Plano gerado por IA · Consulta um nutricionista em Maputo para acompanhamento
        </p>
      </div>
    </div>
  );
}
